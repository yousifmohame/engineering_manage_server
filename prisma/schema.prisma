// إعدادات Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // تأكد من وجود الرابط في ملف env أو prisma.config.ts
}

// ---------------------------------------------------------
// 1. جدول المستخدمين
// ---------------------------------------------------------
model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  phone     String?  @unique
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// 2. الحسابات المالية المركزية (تدمج البنوك والخزنة)
// ---------------------------------------------------------
model FinancialAccount {
  id       String @id @default(uuid())
  name     String // اسم الحساب (مثال: خزنة البيت، البنك الأهلي، CIB)
  type     String // نوع الحساب: "SAFE" (خزنة)، "BANK" (بنك)
  currency String @default("SAR") // العملة الافتراضية للحساب
  balance  Float  @default(0) // الرصيد الحالي

  // بيانات خاصة بالبنوك (تكون فارغة إذا كان الحساب خزنة)
  accountNumber String?
  iban          String?
  swiftCode     String?

  // ✨ تحديث: العلاقات مع المعاملات (المسحوبة والمودعة)
  transactions Transaction[] @relation("AccountTransactions") // المعاملات العادية والمسحوبات
  transfersIn  Transaction[] @relation("IncomingTransfers") // التحويلات الواردة لهذا الحساب

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------
// 3. المعاملات المالية المركزية (الواردات، المصروفات، والتحويلات)
// ---------------------------------------------------------
model Transaction {
  id   String @id @default(uuid())
  type String // "INCOME" (إيراد), "EXPENSE" (مصروف), "TRANSFER" (تحويل)

  amount   Float
  currency String @default("SAR")

  exchangeRate Float  @default(1)
  baseAmount   Float?

  date        DateTime @default(now())
  description String
  category    String? // سيُخزن هنا نوع المصروف (مثال: "أرض" أو "بناء")
  paidBy      String? // ✨ جديد: سيُخزن هنا من دفع (مثال: "أنا" أو "أخي")

  referenceNumber String?
  attachmentUrl   String?
  transactionHash String? @unique

  // ✨ تحديث: أضفنا علامة الاستفهامة (?) لنجعل الحساب اختيارياً في حالة الدفع من الجيب الخاص
  accountId String?
  account   FinancialAccount? @relation("AccountTransactions", fields: [accountId], references: [id])

  toAccountId String?
  toAccount   FinancialAccount? @relation("IncomingTransfers", fields: [toAccountId], references: [id])

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])

  partnershipId String?
  partnership   Partnership? @relation(fields: [partnershipId], references: [id])

  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// 4. إدارة الأصول والذهب
// ---------------------------------------------------------
model Asset {
  id          String   @id @default(uuid())
  type        String // "GOLD", "OTHER"
  subType     String? // سبيكة، جنيه ذهب، مشغولات
  karat       Int?     @default(24)
  weight      Float? // الوزن بالجرام
  buyPrice    Float // إجمالي مبلغ الشراء
  date        DateTime @default(now())
  description String?
}

// ---------------------------------------------------------
// 5. العقارات وملحقاتها
// ---------------------------------------------------------
model Property {
  id         String  @id @default(uuid())
  name       String
  location   String?
  totalPrice Float

  installments Installment[]
  files        File[]
  transactions Transaction[] // المدفوعات المرتبطة بالعقار

  createdAt DateTime @default(now())
}

model Installment {
  id         String   @id @default(uuid())
  amount     Float
  dueDate    DateTime
  isPaid     Boolean  @default(false)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------
// 6. الشراكات (شراكة نظمي، يوسف، وأي شراكة مستقبلية)
// ---------------------------------------------------------
model Partnership {
  id                String   @id @default(uuid())
  name              String // اسم الشراكة
  companyName       String?
  establishmentDate DateTime @default(now())
  primaryCurrency   String   @default("SAR")

  capital Float @default(0) // رأس المال
  reserve Float @default(0) // الاحتياطي

  showCapital    Boolean @default(true)
  showProfits    Boolean @default(true)
  showAiAnalysis Boolean @default(true)

  partners     Partner[]
  transactions Transaction[] // الإيرادات والمصروفات الخاصة بالشراكة
  loans        Loan[] // السلف المرتبطة
}

model Partner {
  id            String      @id @default(uuid())
  name          String
  email         String?
  sharePercent  Float // نسبة الشريك (مثلاً 50%)
  partnershipId String
  partnership   Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
}

// السلف والمساهمات بين الشركاء
model Loan {
  id                    String    @id @default(uuid())
  amount                Float
  currency              String    @default("SAR")
  type                  String // "LOAN" (سلفة) أو "CONTRIBUTION" (مساهمة رأس مال)
  fromPartner           String // الشريك المانح
  toPartner             String // الشريك المستفيد
  description           String
  repaymentDate         DateTime?
  deductFromLiquidation Boolean   @default(false) // الخصم عند التصفية

  partnershipId String?
  partnership   Partnership? @relation(fields: [partnershipId], references: [id])

  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// 7. إدارة الملفات العامة
// ---------------------------------------------------------
model File {
  id   String @id @default(uuid())
  name String
  url  String

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// نموذج يمثل الملف أو المجلد
model FileNode {
  id       String  @id @default(uuid())
  name     String // اسم الملف أو المجلد
  isFolder Boolean @default(false) // هل هو مجلد أم ملف؟
  mimeType String? // نوع الملف (مثال: application/pdf)
  size     Int? // حجم الملف بالبايت
  url      String? // مسار الملف الحالي على السيرفر

  // لدعم المجلدات المتداخلة (مجلد داخل مجلد)
  parentId String?
  parent   FileNode?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children FileNode[] @relation("FolderChildren")

  // لدعم الإصدارات المتعددة للملف
  versions FileVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// نموذج لتتبع التعديلات (Versions) لكل ملف
model FileVersion {
  id         String   @id @default(uuid())
  fileNodeId String
  fileNode   FileNode @relation(fields: [fileNodeId], references: [id], onDelete: Cascade)

  url        String // مسار هذه النسخة القديمة
  size       Int // حجم هذه النسخة
  versionNum Int // رقم الإصدار (1, 2, 3...)

  createdAt DateTime @default(now())
}

// جدول لحفظ سجل تحليلات الذكاء الاصطناعي
model AiAnalysisHistory {
  id        String   @id @default(uuid())
  prompt    String // السؤال الذي طرحه المستخدم
  response  String // إجابة الذكاء الاصطناعي
  createdAt DateTime @default(now()) // تاريخ ووقت التحليل
}

// جدول إدارة العقارات
model RealEstate {
  id              String              @id @default(uuid())
  name            String // اسم العقار (مثال: شقة التجمع)
  type            String? // نوع العقار (شقة، فيلا، إلخ)
  location        String? // الموقع
  status          String              @default("متاح") // الحالة
  totalPrice      Float // السعر الإجمالي
  currency        String              @default("SAR") // العملة
  paidAmount      Float               @default(0) // الدفعة المقدمة / المدفوع
  remainingAmount Float               @default(0) // المتبقي
  progress        Float               @default(0) // نسبة السداد المئوية
  notes           String? // ملاحظات إضافية
  imageUrl        String?
  partners        RealEstatePartner[] @relation("RealEstateToPartner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// جدول شركاء العقارات (تم تغيير الاسم لتجنب التعارض)
model RealEstatePartner {
  id         String @id @default(uuid())
  name       String // اسم الشريك
  percentage Float // نسبة الشراكة المئوية

  // العلاقة مع العقارات (شريك واحد يمكن أن يرتبط بعدة عقارات)
  properties RealEstate[] @relation("RealEstateToPartner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------
// 8. الحركات المالية العامة (مخصص للوحة التحكم لعدم التعارض)
// ---------------------------------------------------------
model FinancialMovement {
  id     String   @id @default(uuid())
  title  String // عنوان الحركة (مثال: راتب، إيجار، صيانة)
  amount Float // المبلغ
  type   String // النوع: "INCOME" (دخل) أو "EXPENSE" (مصروف)
  date   DateTime @default(now()) // تاريخ الحركة
  notes  String? // ملاحظات إضافية

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
